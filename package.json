{
  "name": "vine-watcher",
  "version": "0.7.0",
  "description": "Local Amazon Vine watcher that sends Telegram notifications without requesting products.",
  "license": "MIT",
  "type": "commonjs",
  "author": "GabboPenna",
  "repository": {
    "type": "git",
    "url": "https://github.com/GabboPenna/vine-watcher.git"
  },
  "bugs": {
    "url": "https://github.com/GabboPenna/vine-watcher/issues"
  },
  "homepage": "https://github.com/GabboPenna/vine-watcher#readme",
  "keywords": [
    "amazon-vine",
    "telegram",
    "playwright",
    "sqlite",
    "watcher",
    "notifications"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "once": "node src/index.js --once",
    "dry-run:once": "node src/index.js --once --dry-run",
    "login": "node scripts/login.js",
    "login:wait": "node scripts/login.js --wait-seconds 900",
    "login:server": "node scripts/login.js --wait-file /tmp/vine-watcher-login/done",
    "server-login:start": "bash scripts/server-login.sh start",
    "server-login:finish": "bash scripts/server-login.sh finish",
    "server-login:stop": "bash scripts/server-login.sh stop",
    "check:syntax": "node scripts/check-syntax.js",
    "check:bash": "node scripts/check-bash.js",
    "check:secrets": "node scripts/check-secrets.js",
    "check:release": "node scripts/check-release.js",
    "test": "node scripts/test-core.js",
    "validate": "npm run check:syntax && npm run check:bash && npm test && npm run check:secrets && npm run check:release",
    "test:telegram": "node scripts/test-telegram.js",
    "smoke:browser": "node scripts/smoke-browser.js",
    "stats": "node scripts/stats.js",
    "export:csv": "node scripts/export-csv.js",
    "panic:status": "bash scripts/panic.sh status",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d watcher",
    "docker:logs": "docker compose logs -f watcher",
    "docker:login": "docker compose --profile login up login",
    "docker:login:finish": "bash scripts/docker-login-finish.sh"
  },
  "dependencies": {
    "better-sqlite3": ">=11 <14",
    "dotenv": ">=16 <18",
    "playwright": ">=1 <2"
  }
}
