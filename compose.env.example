# Docker Compose wrapper settings
#
# Application settings live in .env. Start from:
#   cp .env.example .env
#
# These variables only customize Docker image selection, host port bindings,
# and where Compose reads the application env file from.

VINE_WATCHER_IMAGE=gabrielepennacchia/vine-watcher:latest
VINE_WATCHER_ENV_FILE=./.env

# Keep noVNC bound to localhost unless you are behind a trusted VPN/reverse proxy.
NOVNC_BIND=127.0.0.1
NOVNC_PORT=6080
NOVNC_PUBLIC_HOST=localhost

# Keep the health API bound to localhost unless you explicitly expose it.
HEALTH_BIND=127.0.0.1

# Optional. If empty, docker-login generates a temporary password.
VNC_PASSWORD=
