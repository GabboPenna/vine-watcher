# Telegram
TELEGRAM_BOT_TOKEN=123456:ABCDEF
TELEGRAM_CHAT_ID=123456789

# Amazon Vine
AMAZON_VINE_BASE_URL=https://www.amazon.it/vine/vine-items
SCAN_ALL_ITEMS=false
# Optional full override:
# SECTIONS_JSON=[{"name":"Recommended for you","url":"https://www.amazon.it/vine/vine-items?queue=potluck","enabled":true}]
# Optional extra URLs:
# EXTRA_SECTIONS_JSON=[{"name":"Manual category","url":"https://www.amazon.it/vine/vine-items?queue=encore&search=zigbee","enabled":true}]

# Scanner
SCAN_INTERVAL_SECONDS=60
SCAN_JITTER_SECONDS=15
MIN_SCORE_TO_NOTIFY=15
MAX_NOTIFICATIONS_PER_CYCLE=5
HEADLESS=true
PAGE_TIMEOUT_SECONDS=45
PAGE_SETTLE_SECONDS=3
SECTION_DELAY_SECONDS=3

# Local storage
DATABASE_PATH=./data/vine-watcher.sqlite
PLAYWRIGHT_USER_DATA_DIR=./data/chromium-profile

# Logs and errors
LOG_LEVEL=info
NOTIFY_CRITICAL_ERRORS=true
CRITICAL_NOTIFICATION_COOLDOWN_SECONDS=900
EXIT_ON_SESSION_ATTENTION=false
